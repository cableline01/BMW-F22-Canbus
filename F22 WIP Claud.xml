<?xml version="1.0" encoding="UTF-8"?>
<RealDashCAN version="2">
  <frames>

    <!-- ===============================================================
         BMW F22 M240i — RealDash CAN XML
         MHD Stage 2 HPFP | XHP | Flex Fuel (E-blend)

         Signal status:
           [CONFIRMED]  — Validated against OBD2 or multiple data sources
           [VERIFIED]   — Validated against captured CSV data
           [IN XML]     — Was in original XML, not independently verified
           [EMPIRICAL]  — Found by CAN reverse engineering, needs WOT run to fully confirm
           [UNVERIFIED] — Formula uncertain, use with caution
         =============================================================== -->

    <!-- ========================= ENGINE ========================= -->

    <frame canId="0x0A5" length="8">
      <!-- [CONFIRMED] RPM — bytes[5-6] little-endian / 4
           Validated: idle=663 RPM matches OBD2 PID 0x0C (660 RPM)
           Math: raw_16bit_LE / 4 = RPM | Range: 0-8000 rpm -->
      <value targetId="37" offset="5" length="2"
             units="rpm" rangeMin="0" rangeMax="8000"
             conversion="V/4"/>

      <!-- [IN XML] Engine Torque — 12-bit packed at bits 16-27
           Math: (raw_12bit_LE * 0.5) - 1023.5 = Nm | Range: -1024 to +1024 Nm
           Note: also covers MAP pressure range at low values (~0 mbar at idle) -->
      <value targetId="207" startbit="16" bitcount="12"
             units="Nm" rangeMin="-1024" rangeMax="1024"
             conversion="V*0.5-1023.5"/>

      <!-- [IN XML] Gearbox / drivetrain torque — 12-bit packed at bits 28-39 -->
      <value name="Gearbox Torque" startbit="28" bitcount="12"
             units="Nm" rangeMin="-1024" rangeMax="1024"
             conversion="V*0.5-1023.5"/>
    </frame>

    <!-- [CONFIRMED] Coolant + Oil Temperature
         Math: raw_byte - 48 = °C | Confirmed correct. -->
    <frame canId="0x3F9" length="8">
      <value targetId="14" offset="4" length="1"
             units="Celsius" rangeMin="-10" rangeMax="130"
             conversion="V-48"/>  <!-- Coolant Temp -->
      <value targetId="152" offset="5" length="1"
             units="Celsius" rangeMin="-10" rangeMax="160"
             conversion="V-48"/>  <!-- Engine Oil Temp -->
    </frame>

    <!-- [CONFIRMED] Throttle — 12-bit LE at bits 32-43
         [EMPIRICAL]  Boost Pressure — byte[6], absolute kPa, 1 kPa/bit
         Boost math: (raw_kPa - 101.325) / 6.895 = psi gauge
           Idle ~0 psi (103 kPa abs), max confirmed 22.3 psi (255 kPa = sensor ceiling)
           Stage 2 E-blend targets 25-30 psi — capture WOT run to verify ceiling
         FIX: was targetid (lowercase), endian (wrong attr name), scale (invalid attr),
              offset=0 length=2 pointed at rolling timestamp bytes NOT boost -->
    <frame canId="0x0D9" length="8">
      <value targetId="42" startbit="32" bitcount="12"
             units="%" rangeMin="0" rangeMax="100"
             conversion="V/40"/>  <!-- Throttle Position -->

      <value targetId="84" offset="6" length="1"
             units="psi" rangeMin="-15" rangeMax="30"
             conversion="(V-101.325)/6.895"/>  <!-- Boost Pressure (psi gauge) -->

      <!-- Also expose as raw kPa absolute for logging -->
      <value name="Boost kPa Abs" offset="6" length="1"
             units="kPa" rangeMin="70" rangeMax="255"
             conversion="V"/>  <!-- Boost raw kPa absolute -->

      <!-- [EMPIRICAL] Engine Load via byte[2]
           FIX: 0x397 had broken formula V-65310 — use this instead
           Math: raw_byte * 0.392 = % | DBC-sourced, empirically plausible -->
      <value targetId="100" offset="2" length="1"
             units="%" rangeMin="0" rangeMax="100"
             conversion="V*0.392"/>  <!-- Engine Load % -->
    </frame>

    <!-- [IN XML] Charge Air Temp (Post-Intercooler)
         Math: raw_byte - 40 = °C | UNVERIFIED — 0x6F4 not seen in captured data
         If this shows no data, the signal may be on a different ID or need a WOT run -->
    <frame canId="0x6F4" length="8">
      <value name="Charge Air Temp" offset="2" length="1"
             units="Celsius" rangeMin="-40" rangeMax="150"
             conversion="V-40"/>
    </frame>

    <!-- ========================= VEHICLE ========================= -->

    <!-- [CONFIRMED] Vehicle Speed
         Math: raw_16bit_LE * 0.015625 = km/h | Max verified: 148.9 km/h -->
    <frame canId="0x1A1" length="8">
      <value targetId="64" offset="2" length="2"
             units="KPH" rangeMin="0" rangeMax="300"
             conversion="V*0.015625"/>
    </frame>

    <!-- [CONFIRMED] Ambient Temperature
         Math: raw_byte * 0.5 - 40 = °C | Verified: 26.5-28°C in recording -->
    <frame canId="0x2CA" length="8">
      <value targetId="173" offset="0" length="1"
             units="Celsius" rangeMin="-40" rangeMax="60"
             conversion="V*0.5-40"/>
    </frame>

    <!-- [CONFIRMED] Battery Voltage
         Math: (raw_12bit & 0xFFF) / 68 = Volts -->
    <frame canId="0x281" length="8">
      <value targetId="12" offset="0" length="2"
             conversion="(V &amp; 0xfff) / 68"/>
    </frame>

    <!-- [IN XML] Turn Signals -->
    <frame canId="0x1F6" length="8">
      <value targetId="160" units="bit" startbit="4" bitcount="1"/>  <!-- Turn Signal Left -->
      <value targetId="161" units="bit" startbit="5" bitcount="1"/>  <!-- Turn Signal Right -->
    </frame>

    <!-- [IN XML] Headlights -->
    <frame canId="0x21A" length="8">
      <value targetId="157" units="bit" startbit="1"  bitcount="1"/>  <!-- High Beam -->
      <value targetId="156" units="bit" startbit="13" bitcount="1"/>  <!-- Low Beam -->
    </frame>

    <!-- [IN XML] Doors / Hood / Trunk
         Note: targetId="163" on trunk does NOT conflict with CAN ID 0x163 —
         targetIds and CAN IDs are different numbering spaces -->
    <frame canId="0x2FC" length="8">
      <value targetId="482" units="bit" startbit="10" bitcount="1"/>  <!-- Driver Door -->
      <value targetId="481" units="bit" startbit="8"  bitcount="1"/>  <!-- Passenger Door -->
      <value targetId="487" units="bit" startbit="16" bitcount="1"/>  <!-- Hood -->
      <value targetId="163" units="bit" startbit="17" bitcount="1"/>  <!-- Trunk -->
    </frame>

    <!-- [IN XML] Seat Belt Warning -->
    <frame canId="0x581" length="8">
      <value targetId="168" startbit="24" bitcount="1"/>
    </frame>

    <!-- [IN XML] Dashboard Brightness -->
    <frame canId="0x202" length="8">
      <value targetId="274" offset="0" length="1" conversion="V/2.55"/>
    </frame>

    <!-- [IN XML] Speed Limit Sign Detection (camera) -->
    <frame canId="0x28F" length="8">
      <value name="Speed Limit Sign" offset="0" length="1"
             enum="129:5,130:10,131:15,132:20,133:25,134:30,135:35,136:40,137:45,138:50,139:55,140:60,141:65,142:70,143:75,144:80,145:85,146:90,147:95,148:100,#:--"/>
    </frame>

    <!-- [IN XML] Lane Departure -->
    <frame canId="0x327" length="8">
      <value name="Lane Departure" offset="2" length="1"/>
    </frame>

    <!-- [IN XML] BC (Board Computer) Button -->
    <frame canId="0x1EE" length="8">
      <value name="BC Button" startbit="6" bitcount="1"/>
    </frame>

    <!-- [IN XML] Steering Angle
         Math: raw_16bit_LE / 22.75 - 1440 = degrees
         VALIDATION: max hit 1440° = 0xFFFF invalid sentinel (car stationary/ignition off)
           Added rangeMin/rangeMax to clamp out invalid frames.
           Real lock-to-lock range is approx ±600°.
         NOTE: 0x302 is ALSO used for EGS transmission data — verify steering
               shows correctly and doesn't conflict with gear/torque readings. -->
    <frame canId="0x302" length="8">
      <value targetId="229" offset="2" length="2"
             rangeMin="-700" rangeMax="700"
             conversion="V/22.75-1440"/>
    </frame>

    <!-- [IN XML] Brake Pressed
         Math: (raw_byte - 125) * -1 | offset=3 -->
    <frame canId="0x0EF" length="8">
      <value name="Brake Pressed" offset="3" length="1"
             conversion="(V-125)*-1"/>
    </frame>

    <!-- [IN XML] Emergency Brake -->
    <frame canId="0x34F" length="8">
      <value targetId="164" startbit="0" bitcount="1" units="bits"/>
    </frame>

    <!-- [IN XML] Start/Stop Button -->
    <frame canId="0x12F" length="8">
      <value targetId="154" units="bit" startbit="44" bitcount="1"/>
    </frame>

    <!-- [IN XML] Check Engine Light (bit 1 of byte 5) -->
    <frame canId="0x1B4" length="8">
      <value targetId="65" offset="5" length="1" bitmask="0x02"/>
    </frame>

    <!-- [IN XML] DSC Composite Acceleration (chassis sensor fusion)
         FIX: was incorrectly mapped as "Cruise Control" — 0x289 is DSC data
         Math: (raw_16bit_LE * -0.0002) + 6.4859 = g
         VALIDATION: 0x289, 0x199, 0x19A all active in recording ✓
         Using named values here so targetId 6/7 is reserved for individual wheel sensors below -->
    <frame canId="0x289" length="8">
      <value name="DSC Lateral Accel"      offset="2" length="2"
             conversion="(V*-0.0002)+6.4859"/>
      <value name="DSC Long Accel"         offset="4" length="2"
             conversion="(V*-0.0002)+6.4859"/>
    </frame>

    <!-- [IN XML] Individual Wheel Acceleration Sensors — feed RealDash targetId 6/7 -->
    <frame canId="0x199" length="8">
      <value targetId="6" offset="2" length="2"
             conversion="(V*-0.0002)+6.4859"/>  <!-- Lateral Accel (g) -->
    </frame>

    <frame canId="0x19A" length="8">
      <value targetId="7" offset="2" length="2"
             conversion="(V*-0.0002)+6.4859"/>  <!-- Long Accel (g) -->
    </frame>

    <!-- [IN XML] ABS Warning + Wheel Slip -->
    <frame canId="0x173" length="8">
      <value targetId="273" offset="3" length="2"/>
      <value name="WheelSlip" startbit="6" bitcount="5"/>
    </frame>

    <!-- ========================= TRANSMISSION ========================= -->

    <!-- [IN XML] Gear Display Letter — 4-bit packed at bits 40-43
         FIX: had />/>  (duplicate close) — now single />
         Enum: P/N/R/D/1-8 -->
    <frame canId="0x0F3" length="8">
      <value targetId="141" startbit="40" bitcount="4"
             enum="0:P,1:N,2:R,4:D,5:1,6:2,7:3,8:4,9:5,10:6,11:7,12:8"/>
    </frame>

    <!-- [IN XML] Drive Mode -->
    <frame canId="0x3A7" length="8">
      <value name="DriveMode" offset="4" length="1"
             enum="37:SPORT PLUS,36:SPORT,19:COMFORT,71:ECO PRO,17:T/C OFF,38:DSC OFF,#:Error"/>
    </frame>

    <!-- [IN XML] Transmission State + Oil Temp + Manual Mode
         FIX: enum had "23,3" (missing colon) — now "23:3"
         VALIDATION: raw values 17-20 seen in data — added to enum as candidates
           17=P(park), 18=R(reverse selector), 19=N(neutral), 20=D-engage?
           Confirm by doing P→R→N→D shift sequence with isolate.py
         Transmission oil temp: raw_byte - 48 = °C (same formula as engine oil) -->
    <frame canId="0x39A" length="8">
      <value name="Gear Number" offset="3" length="1"
             enum="17:P,18:R,19:N,20:D,21:1,22:2,23:3,24:4,25:5,26:6,27:7,28:8,#:_"/>
      <value name="Dynamic Adapt State" offset="6" length="1"/>
      <value name="Manual Shift" startbit="45" bitcount="1" units="bits"
             enum="0:_,1:Manual"/>
      <value targetId="138" offset="1" length="1"
             units="Celsius" rangeMin="-32" rangeMax="160"
             conversion="V-48"/>  <!-- Transmission Oil Temp -->
    </frame>

    <!-- [IN XML] Cruise Control Set Speed
         FIX: targetId="171" conflict resolved — 0x289 no longer uses 171
         Math: raw_byte - 54 = km/h -->
    <frame canId="0x1C6" length="8">
      <value name="Cruise Set Speed" targetId="171" offset="1" length="1"
             conversion="V-54"/>
    </frame>

    <!-- ========================= FUEL ========================= -->

    <!-- [IN XML] Fuel Level, Fuel Range, Odometer
         FIX: Fuel Level was "(B0+B1)+19" — that formula is wrong/placeholder
         UNVERIFIED: proper fuel level formula needs calibration against actual gauge.
         Placeholder: B0*256+B1 = raw 16-bit, divide by 65535 * 100 = %
         If that reads wrong, try: (B0*256+B1)/655.35  or  V*0.0015259 -->
    <frame canId="0x330" length="8">
      <value name="Fuel Range" startbit="48" bitcount="16"
             conversion="V/16*0.5213711922"/>  <!-- Fuel Range (km) -->
      <value targetId="170" offset="4" length="2"
             units="%" rangeMin="0" rangeMax="100"
             conversion="B0*256+B1)/655.35"/>  <!-- Fuel Level % (UNVERIFIED — calibrate against gauge) -->
      <value targetId="310" offset="0" length="3"/>  <!-- Odometer (km raw) -->
    </frame>

    <!-- [IN XML] Average Fuel Consumption (L/100km) -->
    <frame canId="0x362" length="8">
      <value name="Avg Fuel Consumption" offset="0" length="2"
             conversion="235.215 / (((B0 * 256) + B1) * 0.1)"/>
    </frame>

    <!-- [IN XML] Instantaneous Fuel Consumption (L/100km)
         VALIDATION: raw 0xFFFF = invalid (fuel cut / engine off) → adds rangeMax clamp
         Normal range: 0-25 L/100km. Formula correct when engine is fuelling. -->
    <frame canId="0x2C4" length="8">
      <value name="Inst Fuel Consumption" offset="0" length="2"
             units="l/100km" rangeMin="0" rangeMax="50"
             conversion="((B0*256)+B1)*0.1"/>
    </frame>

    <!-- [CONFIRMED] Flex Fuel / Ethanol Content
         Math: raw_byte = ethanol % | Confirmed correct. -->
    <frame canId="0x0EC" length="8">
      <value name="Ethanol Content %" offset="0" length="1"
             rangeMin="0" rangeMax="100"
             conversion="V"/>
      <value targetId="499" offset="1" length="1"/>  <!-- Ethanol sensor temp (raw) -->
    </frame>

    <!-- ========================= WARNING / STATUS FLAGS ========================= -->

    <!-- [IN XML] Warning Messages (instrument cluster alerts)
         FIX: was using id= (now canId=), had duplicate/malformed enum entries,
              both values used same targetId=248 (second now uses name instead) -->
    <frame canId="0x336" length="8">
      <value targetId="248" offset="1" length="1"
             enum="0:_,3:Ignition ON,14:Passenger Door Open,15:Driver Door Open,18:Hood Open,19:Low Fuel,28:Engine Oil Level Low,29:Engine Fault - Reduced Power,30:Engine Stop - Drive Carefully,35:Fuel Cap Loose,36:DSC/ABS Error,39:OVERHEATING STOP NOW,40:Press Brake to Start,41:Service Due,46:Fasten Seat Belt,55:Parking Brake On,63:Check Tire Pressure,66:Key Fob Not Detected,74:Brake Fluid Low,79:Low External Temperature,116:Left Blinker Failed,124:Right Blinker Failed,133:Right Rear Light Failure,164:Windshield Fluid Low,166:Coolant Low,168:Transmission Malfunction,205:Press Brake To Select Gear,275:Low Fuel,281:Service Due,284:Service Overdue,402:Apply Foot Brake,#:_"/>
      <value name="Warning Byte 2" offset="2" length="1"
             enum="0:_,275:Low Fuel,281:Service Due,284:Service Overdue,402:Apply Foot Brake,#:_"/>
    </frame>

    <!-- ========================= GPS / CLOCK / MISC ========================= -->

    <!-- [IN XML] GPS Position -->
    <frame canId="0x34A" length="8">
      <value targetId="23" offset="0" length="4" conversion="V/11930464.7-360"/>  <!-- GPS Longitude -->
      <value targetId="22" offset="4" length="4" conversion="V/11930464.7"/>       <!-- GPS Latitude -->
    </frame>

    <!-- [IN XML] GPS Heading + Altitude (big-endian) -->
    <frame canId="0x34C" length="8" endianness="big">
      <value targetId="209" name="GPS Heading"  offset="0" length="2" conversion="V/10" units="deg"/>
      <value targetId="21"  name="GPS Altitude" offset="2" length="2" conversion="V"    units="m"/>
    </frame>

    <!-- [IN XML] Speed Limit Sign -->
    <frame canId="0x28F" length="8">
      <value name="Speed Limit Sign" offset="0" length="1"
             enum="129:5,130:10,131:15,132:20,133:25,134:30,135:35,136:40,137:45,138:50,139:55,140:60,141:65,142:70,143:75,144:80,145:85,146:90,147:95,148:100,#:--"/>
    </frame>

  </frames>
</RealDashCAN>
